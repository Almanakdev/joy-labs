# ----- Database (Supabase Postgres) -----
# Connection pooling URL (used by Prisma Client at runtime)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ----- Solana -----
# mainnet-beta | devnet | testnet
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"

# ----- Helius (RPC + enhanced APIs) -----
HELIUS_API_KEY="your-helius-api-key"
NEXT_PUBLIC_HELIUS_RPC_URL="https://devnet.helius-rpc.com/?api-key=your-helius-api-key"

# ----- App -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Minimum Work Score required to unlock the Launch Arena
NEXT_PUBLIC_MIN_LAUNCH_SCORE="750"

# ----- Feature flags -----
# When true the app serves bundled mock data and skips live DB/RPC calls.
NEXT_PUBLIC_USE_MOCKS="true"
